{
  "name": "pi-proof",
  "version": "1.1.0",
  "description": "Proof-first Pi extension that uses a red-green-refactor cycle when behavior should be specified in tests first, with built-in parsing for popular test frameworks.",
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "video": "https://github.com/kreek/pi-proof/raw/refs/heads/main/assets/release/demo.mp4",
    "image": "https://github.com/kreek/pi-proof/raw/refs/heads/main/assets/release/demo.gif"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "install-ext": "mkdir -p ~/.pi/agent/extensions && ln -sfn \"$(pwd)\" ~/.pi/agent/extensions/pi-proof && echo 'Installed to ~/.pi/agent/extensions/pi-proof -- run /reload in Pi to activate'",
    "install-hooks": "git config core.hooksPath .githooks && echo 'Installed Git hooks from .githooks/'",
    "uninstall-ext": "rm -f ~/.pi/agent/extensions/pi-proof && echo 'Uninstalled'",
    "lint": "biome check",
    "lint:staged": "biome check --staged --no-errors-on-unmatched",
    "lint:fix": "biome check --write",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kreek/pi-proof.git"
  },
  "author": "Alastair Dawson",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "proof",
    "proof-first",
    "red-green-refactor",
    "testing",
    "agent-workflow",
    "coding-agent",
    "vitest",
    "jest",
    "pytest",
    "rspec"
  ]
}

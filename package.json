{
  "name": "pi-tdd",
  "version": "0.1.0",
  "description": "TDD enforcement gate for pi coding agent — enforces SPEC/RED/GREEN/REFACTOR cycle with pre-flight and post-flight LLM reviews at cycle boundaries",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "pi:install": "npm run build && pi install -l .",
    "pi:install:global": "npm run build && pi install .",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "tdd",
    "pi",
    "pi-package",
    "extension",
    "coding-agent"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "license": "MIT",
  "peerDependencies": {
    "@mariozechner/pi-ai": "^0.65.2",
    "@mariozechner/pi-coding-agent": "^0.65.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
